# ============================================================================
# RAZOCONNECT - PLANTILLA DE VARIABLES DE ENTORNO
# ============================================================================
# IMPORTANTE: Este archivo es una plantilla. NO contiene valores reales.
# Copia este archivo a .env y configura los valores correctos.
# NUNCA commitees el archivo .env al repositorio.
# ============================================================================

# --- SISTEMA ---
PORT=8080
# NODE_ENV: development (usa Redis mock en RAM) | production (conecta a Redis real)
NODE_ENV=development

# --- BASE DE DATOS ---
# Azure PostgreSQL o servidor local
DB_HOST=tu-servidor.postgres.database.azure.com
DB_PORT=5432
DB_NAME=nombre_base_datos
DB_USER=usuario_db
DB_PASSWORD=contraseña_segura_minimo_16_caracteres
DB_SSL=true

# --- SEGURIDAD Y AUTENTICACIÓN ---
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=genera_un_secreto_aleatorio_de_32_caracteres_minimo
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=10
SUPER_ADMIN_KEY=clave_super_segura_para_crear_administradores

# --- SESIONES ---
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=genera_otro_secreto_aleatorio_diferente_al_jwt

# --- REDIS (Rate Limiting & Tokens) ---
# SMART FALLBACK: En NODE_ENV=development, usa RAM local (sin conexión a Redis)
# En NODE_ENV=production, conecta a Redis remoto (Upstash o Azure)
# 
# Opción 1: REDIS_URL (Recomendado para Upstash)
# REDIS_URL=rediss://default:tu_password@tu-instancia.upstash.io:6380
#
# Opción 2: Variables separadas (Azure Cache for Redis)
REDIS_HOST=tu-instancia.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=tu_clave_primaria_o_secundaria

# --- URLS ---
FRONTEND_BASE_URL=https://tu-dominio.com

# --- CORREO (BREVO / SMTP) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=tu_usuario_smtp
SMTP_PASS=tu_contraseña_smtp
SMTP_FROM=Tu Empresa <no-reply@tu-dominio.com>
ADMIN_EMAIL=admin@tu-dominio.com

# --- GOOGLE AUTH (OAuth 2.0) ---
# Obtener en: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=tu_client_secret

# --- MERCADO PAGO ---
# Obtener en: https://www.mercadopago.com.mx/developers/panel/credentials
# Usar TEST credentials en desarrollo, PRODUCTION en producción
MP_ACCESS_TOKEN=TEST-tu_access_token_de_mercadopago

# --- CLOUDINARY (Almacenamiento de Imágenes) ---
# Obtener en: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# --- PRUEBAS MULTI TENANCY (Opcional) ---
# Descomentar solo para forzar un tenant específico en desarrollo
# FORCE_TENANT_ID=1

# ============================================================================
# INSTRUCCIONES DE SEGURIDAD
# ============================================================================
#
# 1. GENERAR SECRETOS FUERTES:
#    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# 2. REQUISITOS DE SECRETOS:
#    - Mínimo 16 caracteres
#    - Incluir mayúsculas, minúsculas, números y símbolos
#    - NO usar palabras comunes (password, secret, admin, etc.)
#    - NO reutilizar secretos entre entornos
#
# 3. PROTEGER EL ARCHIVO .env:
#    - Verificar que esté en .gitignore
#    - NO compartir por email, chat o repositorios
#    - Usar gestores de secretos en producción (Azure Key Vault, AWS Secrets Manager)
#
# 4. ROTAR SECRETOS REGULARMENTE:
#    - Cada 90 días en producción
#    - Inmediatamente si hay sospecha de compromiso
#
# ============================================================================
