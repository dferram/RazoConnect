<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{title}}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
            background-color: #f5f5f5;
            padding: 20px;
            line-height: 1.6;
        }
        .email-container {
            max-width: 600px;
            margin: 0 auto;
            background-color: #ffffff;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
        }
        .email-header {
            background: linear-gradient(135deg, #F97316 0%, #ea580c 100%);
            padding: 30px 20px;
            text-align: center;
        }
        .email-header img {
            max-width: 180px;
            height: auto;
            margin-bottom: 10px;
        }
        .email-header h1 {
            color: #ffffff;
            font-size: 24px;
            font-weight: 600;
            margin: 0;
        }
        .email-body {
            padding: 40px 30px;
            color: #374151;
        }
        .email-body h2 {
            color: #111827;
            font-size: 20px;
            margin-bottom: 16px;
            font-weight: 600;
        }
        .email-body p {
            margin-bottom: 16px;
            font-size: 15px;
            color: #4b5563;
        }
        .greeting {
            font-size: 16px;
            color: #111827;
            font-weight: 500;
            margin-bottom: 20px;
        }
        .message-content {
            background-color: #fef3c7;
            border-left: 4px solid #F97316;
            padding: 16px 20px;
            margin: 24px 0;
            border-radius: 6px;
        }
        .cta-button {
            display: inline-block;
            padding: 14px 32px;
            background: linear-gradient(135deg, #F97316 0%, #ea580c 100%);
            color: #ffffff !important;
            text-decoration: none;
            border-radius: 8px;
            font-weight: 600;
            font-size: 15px;
            margin: 24px 0;
            transition: transform 0.2s;
            box-shadow: 0 4px 6px rgba(249, 115, 22, 0.3);
        }
        .cta-button:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 12px rgba(249, 115, 22, 0.4);
        }
        .order-details {
            margin: 30px 0;
            border: 1px solid #e5e7eb;
            border-radius: 8px;
            overflow: hidden;
        }
        .order-header {
            background-color: #f9fafb;
            padding: 16px 20px;
            border-bottom: 2px solid #F97316;
        }
        .order-header h3 {
            color: #111827;
            font-size: 18px;
            margin: 0;
            font-weight: 600;
        }
        .order-id {
            color: #F97316;
            font-weight: 700;
        }
        .products-table {
            width: 100%;
            border-collapse: collapse;
        }
        .products-table thead {
            background-color: #F97316;
            color: #ffffff;
        }
        .products-table th {
            padding: 12px 16px;
            text-align: left;
            font-weight: 600;
            font-size: 14px;
        }
        .products-table td {
            padding: 16px;
            border-bottom: 1px solid #e5e7eb;
            font-size: 14px;
            color: #374151;
        }
        .products-table tbody tr:last-child td {
            border-bottom: none;
        }
        .product-image {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 6px;
            border: 1px solid #e5e7eb;
        }
        .product-name {
            font-weight: 500;
            color: #111827;
        }
        .product-variant {
            font-size: 12px;
            color: #6b7280;
            margin-top: 4px;
        }
        .totals-section {
            background-color: #f9fafb;
            padding: 20px;
            border-top: 2px solid #e5e7eb;
        }
        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 8px 0;
            font-size: 15px;
        }
        .total-row.grand-total {
            border-top: 2px solid #F97316;
            margin-top: 12px;
            padding-top: 16px;
            font-size: 18px;
            font-weight: 700;
            color: #111827;
        }
        .total-row.grand-total .amount {
            color: #F97316;
        }
        .email-footer {
            background-color: #f9fafb;
            padding: 30px 20px;
            text-align: center;
            border-top: 1px solid #e5e7eb;
        }
        .email-footer p {
            color: #6b7280;
            font-size: 13px;
            margin-bottom: 8px;
        }
        .email-footer .company-name {
            color: #F97316;
            font-weight: 600;
            font-size: 14px;
        }
        .social-links {
            margin-top: 20px;
        }
        .social-links a {
            display: inline-block;
            margin: 0 8px;
            color: #6b7280;
            text-decoration: none;
            font-size: 12px;
        }
        .divider {
            height: 1px;
            background-color: #e5e7eb;
            margin: 24px 0;
        }
        @media only screen and (max-width: 600px) {
            .email-body {
                padding: 30px 20px;
            }
            .products-table th,
            .products-table td {
                padding: 10px 8px;
                font-size: 13px;
            }
            .product-image {
                width: 50px;
                height: 50px;
            }
        }
    </style>
</head>
<body>
    <div class="email-container">
        <!-- Header -->
        <div class="email-header">
            <img src="https://razo.com.mx/assets/logo-razo.png" alt="RazoConnect Logo" onerror="this.src='https://via.placeholder.com/180x50/F97316/ffffff?text=RazoConnect'">
            <h1>{{title}}</h1>
        </div>

        <!-- Body -->
        <div class="email-body">
            {{#if name}}
            <p class="greeting">Hola {{name}},</p>
            {{/if}}

            {{#if message}}
            <div class="message-content">
                {{{message}}}
            </div>
            {{/if}}

            {{#if orderDetails}}
            <div class="order-details">
                <div class="order-header">
                    <h3>Resumen de tu Pedido <span class="order-id">#{{orderDetails.id}}</span></h3>
                </div>
                
                <table class="products-table">
                    <thead>
                        <tr>
                            <th>Producto</th>
                            <th style="text-align: center;">Cantidad</th>
                            <th style="text-align: right;">Precio</th>
                        </tr>
                    </thead>
                    <tbody>
                        {{#each orderDetails.items}}
                        <tr>
                            <td>
                                <div style="display: flex; align-items: center; gap: 12px;">
                                    <img src="{{this.image}}" alt="{{this.name}}" class="product-image" onerror="this.src='https://via.placeholder.com/60x60/e5e7eb/6b7280?text=Producto'">
                                    <div>
                                        <div class="product-name">{{this.name}}</div>
                                        {{#if this.variant}}
                                        <div class="product-variant">{{this.variant}}</div>
                                        {{/if}}
                                    </div>
                                </div>
                            </td>
                            <td style="text-align: center; font-weight: 500;">{{this.quantity}}</td>
                            <td style="text-align: right; font-weight: 600; color: #111827;">{{this.price}}</td>
                        </tr>
                        {{/each}}
                    </tbody>
                </table>

                <div class="totals-section">
                    <div class="total-row">
                        <span>Subtotal:</span>
                        <span style="font-weight: 600;">{{orderDetails.subtotal}}</span>
                    </div>
                    {{#if orderDetails.shipping}}
                    <div class="total-row">
                        <span>Envío:</span>
                        <span style="font-weight: 600;">{{orderDetails.shipping}}</span>
                    </div>
                    {{/if}}
                    {{#if orderDetails.discount}}
                    <div class="total-row" style="color: #059669;">
                        <span>Descuento:</span>
                        <span style="font-weight: 600;">-{{orderDetails.discount}}</span>
                    </div>
                    {{/if}}
                    <div class="total-row grand-total">
                        <span>Total:</span>
                        <span class="amount">{{orderDetails.total}}</span>
                    </div>
                </div>
            </div>
            {{/if}}

            {{#if buttonText}}
            <div style="text-align: center;">
                <a href="{{buttonUrl}}" class="cta-button">{{buttonText}}</a>
            </div>
            {{/if}}

            {{#if additionalInfo}}
            <div class="divider"></div>
            <p style="font-size: 14px; color: #6b7280;">
                {{{additionalInfo}}}
            </p>
            {{/if}}
        </div>

        <!-- Footer -->
        <div class="email-footer">
            <p class="company-name">RazoConnect</p>
            <p>Tu socio de confianza en soluciones de inventario y e-commerce</p>
            <div class="divider" style="margin: 20px auto; max-width: 200px;"></div>
            <p style="font-size: 12px;">
                Si tienes alguna pregunta, contáctanos en 
                <a href="mailto:soporte@razo.com.mx" style="color: #F97316; text-decoration: none;">soporte@razo.com.mx</a>
            </p>
            <p style="font-size: 11px; color: #9ca3af; margin-top: 16px;">
                © {{year}} RazoConnect. Todos los derechos reservados.
            </p>
        </div>
    </div>
</body>
</html>
